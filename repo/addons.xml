<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.xstream-player" name="XStream Player" version="1.0.0" provider-name="XStream Player">
        <requires>
            <import addon="xbmc.python" version="3.0.1"/>
            <import addon="script.module.requests" version="2.22.0"/>
            <import addon="pvr.iptvsimple"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="resources/lib/addon.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">XStream Player - Organised M3U &amp; Xtream player</summary>
            <description lang="en_GB">A clean M3U &amp; Xtream player with proper sorting: Live TV, Movies, Series and Replay, plus EPG support.</description>
            <platform>all</platform>
            <license>MIT</license>
            <source>https://github.com/Pesicp/XStream-Player</source>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
    <addon id="repository.xstream-player" name="XStream Player Repository" version="1.0.0" provider-name="Pesicp">
        <extension point="xbmc.addon.repository" name="XStream Player Repository">
            <dir>
                <info compressed="false">https://raw.githubusercontent.com/Pesicp/XStream-Player/main/repo/addons.xml</info>
                <checksum>https://raw.githubusercontent.com/Pesicp/XStream-Player/main/repo/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.githubusercontent.com/Pesicp/XStream-Player/main/repo</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary>XStream Player Repository</summary>
            <description>Repository for XStream Player - Xtream Codes and M3U addon for Kodi</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
