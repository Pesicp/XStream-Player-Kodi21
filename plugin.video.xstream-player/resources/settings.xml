    <category label="Playback">
        <setting label="Stream timeout (seconds)" type="slider" id="stream_timeout" default="15" range="5,1,60"/>
        <setting label="Custom User-Agent" type="text" id="custom_user_agent" default=""/>
        <setting label="Use InputStream Adaptive" type="bool" id="use_inputstream_adaptive" default="false"/>
        <setting label="Pre-fetch all data on startup" type="bool" id="prefetch_on_startup" default="false"/>
    </category>
    <category label="EPG">
        <setting label="Auto-detect EPG from Xtream" type="bool" id="auto_epg" default="true"/>
        <setting label="Show EPG info in Live TV" type="bool" id="show_epg_live" default="true"/>
        <setting label="EPG language priority (e.g. en, fr)" type="text" id="epg_language" default=""/>
        <setting label="Force EPG refresh on startup" type="bool" id="epg_force_refresh_startup" default="false"/>
        <setting label="EPG refresh interval (hours)" type="number" id="epg_refresh" default="4"/>
        <setting label="EPG timezone offset (hours)" type="slider" id="epg_offset" default="0" range="-12,1,12"/>
        <setting label="EPG past days limit" type="number" id="epg_past_days" default="3"/>
        <setting label="Replay days back" type="number" id="replay_days" default="7"/>
    </category>
    <category label="UI &amp; Appearance">
        <setting label="Default sort order" type="labelenum" id="default_sort_order" default="Provider order" values="Provider order|A-Z"/>
    </category>
    <category label="Metadata">
        <setting label="Enable TMDB metadata" type="bool" id="tmdb_enabled" default="false"/>
        <setting label="TMDB API key" type="text" id="tmdb_api_key" default=""/>
        <setting label="Use TMDB posters" type="bool" id="tmdb_posters" default="true"/>
        <setting label="Use TMDB ratings" type="bool" id="tmdb_ratings" default="true"/>
    </category>
    <category label="Parental Control">
        <setting label="Enable parental control" type="bool" id="enable_parental_control" default="false"/>
        <setting label="PIN code" type="number" id="parental_pin" default="0000"/>
    </category>
    <category label="Refresh">
        <setting label="Auto-refresh data" type="bool" id="auto_refresh_enabled" default="true"/>
        <setting label="Auto-refresh interval" type="labelenum" id="auto_refresh_interval" default="24" values="12|24|48|Never"/>
    </category>
    <category label="PVR">
        <setting label="Live TV mode" type="labelenum" id="live_tv_mode" default="PVR (recommended)" values="PVR (recommended)|Plugin list"/>
        <setting label="Auto-sync Live TV to PVR" type="bool" id="auto_sync_pvr" default="true"/>
    </category>
    <category label="Maintenance">
        <setting label="Backup profiles &amp; data" type="action" id="backup_profiles" action="RunPlugin(plugin://plugin.video.xstream-player/?mode=backup_settings)" option="close"/>
        <setting label="Restore profiles &amp; data" type="action" id="restore_profiles" action="RunPlugin(plugin://plugin.video.xstream-player/?mode=restore_settings)" option="close"/>
    </category>
</settings>
